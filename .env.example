# Budgie — Environment Configuration
# Copy this file to .env and fill in SECRET_KEY before first run.
#
# Generate a secure key with:
#   openssl rand -hex 32

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (relative path):
DATABASE_URL=sqlite+aiosqlite:///data/budgie.db
# Docker / Synology (absolute path inside the container):
# DATABASE_URL=sqlite+aiosqlite:////app/data/budgie.db

# ── JWT Authentication ────────────────────────────────────────────────────────
# REQUIRED: change this to a long random string in production!
SECRET_KEY=change-me-to-a-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── File uploads ──────────────────────────────────────────────────────────────
# Local dev (relative path):
UPLOAD_DIR=data/uploads
# Docker / Synology (absolute path inside the container):
# UPLOAD_DIR=/app/data/uploads

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ── Synology NAS / Docker permissions (PUID/PGID) ────────────────────────────
# The container will run as this UID/GID so it can write to the bind-mounted
# ./data volume even when the host directory is owned by a different user.
#
# Find your values on the NAS: ssh admin@nas then run:  id -u && id -g
#
# Uncomment and fill in:
# PUID=1026
# PGID=100
