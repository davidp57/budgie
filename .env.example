# Budgie — Environment Configuration
# Copy this file to .env and fill in SECRET_KEY before first run.
#
# Generate a secure key with:
#   openssl rand -hex 32

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (relative path):
DATABASE_URL=sqlite+aiosqlite:///data/budgie.db
# Docker (set in docker-compose.yml, no need to change here)

# ── JWT Authentication ────────────────────────────────────────────────────────
# REQUIRED: change this to a long random string in production!
SECRET_KEY=change-me-to-a-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── File uploads ──────────────────────────────────────────────────────────────
# Local dev (relative path):
UPLOAD_DIR=data/uploads
# Docker (set in docker-compose.yml, no need to change here)

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Add your Synology domain/IP here for production.
CORS_ORIGINS=http://localhost:5173,https://localhost:5173,http://localhost:8080

# ── WebAuthn (Passkeys) ───────────────────────────────────────────────────────
# RP ID must match the domain serving the frontend (no port, no scheme).
# RP Origin must be the full origin (scheme + domain + optional port).
# For local dev: localhost / http://localhost:5173
# For Synology NAS: use your reverse-proxy domain, e.g.:
#   WEBAUTHN_RP_ID=budgie.your-nas.local
#   WEBAUTHN_ORIGIN=https://budgie.your-nas.local
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Budgie
WEBAUTHN_ORIGIN=https://localhost:5173

# ── Docker / Synology NAS ─────────────────────────────────────────────────────
# External port for the container (default: 8080)
# BUDGIE_PORT=8080
#
# UID/GID to match host user — find yours with: id -u && id -g
# PUID=1026
# PGID=100
